# Codex working files (preserved via workflow artifacts, not git)
# These files are rebuilt each run and would cause merge conflicts
# if multiple PRs commit them. Historical data is preserved in:
# - PR comments (completion summaries)
# - Workflow artifacts (full outputs)
# - Commit messages (change descriptions)
codex-prompt.md
codex-output.md
verifier-context.md

__pycache__/
*.py[cod]
.mypy_cache/
.venv/

# Application JavaScript dependencies belong under frontend/.
# Keep repo-root installs out of git while preserving the workflow-local vendored helpers.
node_modules/
!.github/scripts/node_modules/
!.github/scripts/node_modules/**
node_modules/
dist/
*.tsbuildinfo
